# Application Configuration
APP_NAME="WhatsApp Integration Microservice"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=3000

# Evolution API Configuration
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=SUMlung9541
EVOLUTION_API_TIMEOUT=30.0

# Database (optional, for future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/whatsapp_db

# Redis (optional)
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=whatsapp_ms

# RabbitMQ (optional)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=evolution_exchange

# Logging
LOG_LEVEL=INFO

# CORS (comma-separated origins or * for all)
CORS_ORIGINS=*

# Webhook Base URL (used when registering webhooks with Evolution API)
# WEBHOOK_BASE_URL=https://your-domain.com

# Image Ingestion Configuration (US-ING-001)
# Base directory for all ingestion data
INGESTION_DATA_DIRECTORY=/data
# Subdirectory for storing images (relative to data directory)
INGESTION_IMAGES_SUBDIRECTORY=images
# Subdirectory for metadata files (relative to data directory)
INGESTION_METADATA_SUBDIRECTORY=metadata
# Filename for the metadata CSV
INGESTION_METADATA_FILENAME=images.csv

# =============================================================================
# Application
# =============================================================================
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=INFO

# =============================================================================
# Evolution API
# =============================================================================
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=your-api-key
EVOLUTION_API_TIMEOUT=30.0
CONFIG_SESSION_PHONE_VERSION=2.3000.1034566421

# =============================================================================
# Database (PostgreSQL + pgvector)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/whatsapp_ingestion
EVOLUTION_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/evolution

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379

# =============================================================================
# S3 Storage (boto3 uses IAM Role automatically on EC2/Lambda)
# =============================================================================
STORAGE_BACKEND=s3
S3_BUCKET_NAME=whatsapp-images
S3_PREFIX=images/
S3_REGION=us-east-1
# For MinIO (local dev only):
# S3_ENDPOINT_URL=http://minio:9000
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin

# =============================================================================
# AWS Textract OCR
# =============================================================================
OCR_ENABLED=true
TEXTRACT_REGION=us-east-1

# =============================================================================
# AWS Bedrock / Titan Multimodal Embeddings G1 (1024 dims)
# =============================================================================
EMBEDDINGS_ENABLED=true
BEDROCK_REGION=us-east-1
TITAN_MODEL_ID=amazon.titan-embed-image-v1

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=*

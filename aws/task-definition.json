{
  "family": "batch-processor",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/batch-processor-task-role",
  "containerDefinitions": [
    {
      "name": "batch-processor",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/whatsapp-microservice:latest",
      "command": ["python", "-m", "src.batch.process_pending"],
      "essential": true,
      "environment": [
        { "name": "OCR_LANGUAGE", "value": "spa+eng" },
        { "name": "OCR_ENABLED", "value": "true" },
        { "name": "OCR_BACKEND", "value": "textract" },
        { "name": "EMBEDDINGS_ENABLED", "value": "true" },
        { "name": "STORAGE_BACKEND", "value": "s3" },
        { "name": "LOG_LEVEL", "value": "INFO" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:us-east-1:ACCOUNT_ID:parameter/batch-processor/DATABASE_URL"
        },
        {
          "name": "S3_BUCKET_NAME",
          "valueFrom": "arn:aws:ssm:us-east-1:ACCOUNT_ID:parameter/batch-processor/S3_BUCKET_NAME"
        },
        {
          "name": "S3_PREFIX",
          "valueFrom": "arn:aws:ssm:us-east-1:ACCOUNT_ID:parameter/batch-processor/S3_PREFIX"
        },
        {
          "name": "S3_REGION",
          "valueFrom": "arn:aws:ssm:us-east-1:ACCOUNT_ID:parameter/batch-processor/S3_REGION"
        },
        {
          "name": "TEXTRACT_REGION",
          "valueFrom": "arn:aws:ssm:us-east-1:ACCOUNT_ID:parameter/batch-processor/TEXTRACT_REGION"
        },
        {
          "name": "BEDROCK_REGION",
          "valueFrom": "arn:aws:ssm:us-east-1:ACCOUNT_ID:parameter/batch-processor/BEDROCK_REGION"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/batch-processor",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
